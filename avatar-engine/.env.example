# Environment Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Storage Paths
STORAGE_PATH=./storage
MODELS_PATH=./storage/models
AVATARS_PATH=./storage/avatars
OUTPUTS_PATH=./storage/outputs

# Training Configuration
RUNPOD_API_KEY=
DEFAULT_TRAINING_STEPS=1000
BATCH_SIZE=1
LEARNING_RATE=1e-4

# ComfyUI Configuration
COMFYUI_PATH=./models/ComfyUI
COMFYUI_API_URL=http://localhost:8188
COMFYUI_AUTO_START=true

# Database Configuration
DATABASE_URL=sqlite:///./avatar_engine.db

# Redis Configuration
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# NSFW Settings
ENABLE_NSFW=true
CONTENT_FILTERING=false
SAFETY_CHECKER=false

# Model Configuration
BASE_MODEL=runwayml/stable-diffusion-v1-5
NSFW_MODEL=ChilloutMix
LORA_RANK=64
LORA_ALPHA=64

# Security
SECRET_KEY=change-this-in-production-super-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30